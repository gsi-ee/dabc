	processor febex/module4 std.tuple(trace[16],filter[16])
		trace[0:15]  <- kinpex0.febex4[0:15].trace
		filter[0:15] <- kinpex0.febex4[0:15].filter
		waveform  trace 200 persistent  in trace
		histogram trace 16384,0,16384   in resolution
	end


processor daq/rate std.tuple(time,events) 
	time <- event.time
	events <- event.number
	ratemeter events:time
end




